{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-agent-event.mjs user-prompt-submit",
            "statusMessage": "Recording interview prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-agent-event.mjs pre-tool-use",
            "statusMessage": "Recording interview tool use"
          }
        ]
      }
    ]
  }
}
