{"event":"pre-tool-use","timestamp":"2026-06-18T13:51:50.732Z","tool_name":"Write","tool_input":{"file_path":"/media/fabian/bigcow/projects/asa/wt-advance-spool-to-next-station-api/src/StratusFabTracker.Tests/TestDoubles.cs","content":"using StratusFabTracker.Api.Application;\nusing StratusFabTracker.Api.Domain;\n\nnamespace StratusFabTracker.Tests;\n\n/// <summary>A fixed clock so transition timestamps are deterministic in tests.</summary>\npublic sealed class FakeClock : IClock\n{\n    public FakeClock(DateTimeOffset now) => UtcNow = now;\n    public DateTimeOffset UtcNow { get; set; }\n}\n\n/// <summary>\n/// In-memory repository mirroring <see cref=\"Api.Infrastructure.InMemorySpoolRepository\"/>\n/// but seedable directly from test code.\n/// </summary>\npublic sealed class FakeSpoolRepository : ISpoolRepository\n{\n    private readonly Dictionary<string, Spool> _spools = new();\n    public int UpdateCount { get; private set; }\n\n    public Task<List<Spool>> GetAllAsync() => Task.FromResult(_spools.Values.ToList());\n\n    public Task<Spool?> GetByIdAsync(string id) =>\n        Task.FromResult(_spools.TryGetValue(id, out var s) ? s : null);\n\n    public Task UpdateAsync(Spool spool)\n    {\n        UpdateCount++;\n        _spools[spool.Id] = spool;\n        return Task.CompletedTask;\n    }\n\n    public Task SeedAsync(IEnumerable<Spool> spools)\n    {\n        foreach (var s in spools) _spools[s.Id] = s;\n        return Task.CompletedTask;\n    }\n}\n\n/// <summary>Builds spools for tests without repeating required-member boilerplate.</summary>\npublic static class SpoolBuilder\n{\n    public static Spool At(string id, Station station, DateTimeOffset changedAt, DateOnly? dueDate = null) =>\n        new()\n        {\n            Id = id,\n            PackageId = \"PKG-1\",\n            SpoolNumber = id,\n            DueDate = dueDate ?? new DateOnly(2030, 1, 1),\n            Bom = [],\n            StatusHistory = [new StatusEvent(station, changedAt, \"seed\")]\n        };\n}\n"}}
{"event":"pre-tool-use","timestamp":"2026-06-18T13:51:52.379Z","tool_name":"Edit","tool_input":{"file_path":"/media/fabian/bigcow/projects/asa/wt-dashboard-wip-per-station/src/StratusFabTracker.Api/Application/DashboardService.cs","old_string":"        var spools = await _repository.GetAllAsync();\n        var byStation = Enum.GetValues<Station>()\n            .ToDictionary(s => s.ToString(), s => spools.Count(x => x.CurrentStation == s));\n\n        var now = DateOnly.FromDateTime(DateTime.UtcNow);\n        var pastDue = spools.Count(x => x.DueDate < now && x.CurrentStation != Station.Installed);\n\n        return new DashboardDto(byStation, pastDue);\n    }\n}\n\npublic sealed record DashboardDto(Dictionary<string, int> WipByStation, int PastDueCount);","new_string":"        var spools = await _repository.GetAllAsync();\n\n        // Emit every station in domain order (Detailing -> ... -> Installed),\n        // including zero-count stations. Each spool has exactly one CurrentStation,\n        // so these counts partition the spool set and sum to the total.\n        var wipByStation = Enum.GetValues<Station>()\n            .OrderBy(s => (int)s)\n            .Select(s => new WipStationCount(s.ToString(), spools.Count(x => x.CurrentStation == s)))\n            .ToList();\n\n        var now = DateOnly.FromDateTime(DateTime.UtcNow);\n        var pastDue = spools.Count(x => x.DueDate < now && x.CurrentStation != Station.Installed);\n\n        return new DashboardDto(wipByStation, pastDue);\n    }\n}\n\npublic sealed record WipStationCount(string Station, int Count);\n\npublic sealed record DashboardDto(IReadOnlyList<WipStationCount> WipByStation, int PastDueCount);","replace_all":false}}
