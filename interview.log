{"event":"pre-tool-use","timestamp":"2026-06-18T13:57:54.936Z","tool_name":"Write","tool_input":{"file_path":"/media/fabian/bigcow/projects/asa/wt-dashboard-wip-per-station/src/stratus-fab-tracker-web/src/api.ts","content":"// Shared API types and helpers for the Stratus Fab Tracker dashboard.\n\nexport type WipStationCount = { station: string; count: number };\n\nexport type DashboardDto = {\n  wipByStation: WipStationCount[];\n  pastDueCount: number;\n};\n\nexport type ThroughputDayDto = { day: string; completed: number };\nexport type ThroughputDto = {\n  daily: ThroughputDayDto[];\n  completedPerDay: number;\n  duePerDay: number;\n  keepingUp: boolean;\n};\n\nexport type SpoolSummaryDto = {\n  id: string;\n  spoolNumber: string;\n  packageId: string;\n  dueDate: string;\n  currentStation: string;\n  isPastDue: boolean;\n};\n\n// Domain order of the fabrication chain. The API already returns WIP counts in\n// this order, but the UI also relies on it to label and sort the spool groups.\nexport const STATION_ORDER = [\n  'Detailing',\n  'Cut',\n  'Weld',\n  'QC',\n  'Shipped',\n  'Installed',\n] as const;\n\n// Installed is the terminal station: those spools are complete, not in-flight WIP.\nexport const TERMINAL_STATION = 'Installed';\n\nasync function getJson<T>(url: string): Promise<T> {\n  const res = await fetch(url);\n  if (!res.ok) throw new Error(`Request failed: ${res.status}`);\n  return res.json() as Promise<T>;\n}\n\nexport const api = {\n  dashboard: () => getJson<DashboardDto>('/api/dashboard'),\n  throughput: () => getJson<ThroughputDto>('/api/throughput'),\n  spools: () => getJson<SpoolSummaryDto[]>('/api/spools'),\n};\n"}}
{"event":"pre-tool-use","timestamp":"2026-06-18T13:58:18.839Z","tool_name":"Write","tool_input":{"file_path":"/media/fabian/bigcow/projects/asa/wt-dashboard-wip-per-station/src/stratus-fab-tracker-web/src/style.css","content":":root {\n  --bg: #f5f6f8;\n  --surface: #ffffff;\n  --border: #e2e5ea;\n  --ink: #1d2330;\n  --ink-soft: #5b6472;\n  --accent: #2f6fed;\n  --accent-soft: #eaf1fe;\n  --danger: #c0392b;\n  --danger-soft: #fdecea;\n  --ok: #1e8e5a;\n  --radius: 10px;\n  --shadow: 0 1px 2px rgba(20, 30, 50, 0.06), 0 4px 12px rgba(20, 30, 50, 0.05);\n}\n\n* { box-sizing: border-box; }\n\nbody {\n  margin: 0;\n  font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;\n  background: var(--bg);\n  color: var(--ink);\n  -webkit-font-smoothing: antialiased;\n}\n\na { color: inherit; }\n\n.app-shell {\n  max-width: 1040px;\n  margin: 0 auto;\n  padding: 24px 24px 64px;\n}\n\n.app-header {\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n  gap: 16px;\n  padding-bottom: 16px;\n  margin-bottom: 24px;\n  border-bottom: 1px solid var(--border);\n}\n\n.app-header h1 {\n  font-size: 20px;\n  margin: 0;\n  letter-spacing: -0.01em;\n}\n\n.app-nav { display: flex; gap: 4px; }\n\n.app-nav a {\n  text-decoration: none;\n  font-size: 14px;\n  color: var(--ink-soft);\n  padding: 6px 12px;\n  border-radius: 8px;\n}\n.app-nav a.router-link-active { color: var(--accent); background: var(--accent-soft); font-weight: 600; }\n\n.section-title {\n  font-size: 13px;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: var(--ink-soft);\n  margin: 0 0 12px;\n}\n\n.card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  box-shadow: var(--shadow);\n  padding: 20px;\n}\n\n.card + .card { margin-top: 20px; }\n\n.grid {\n  display: grid;\n  gap: 16px;\n  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\n}\n\n/* Station tiles */\n.tile {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  text-align: left;\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n  padding: 16px;\n  cursor: pointer;\n  font: inherit;\n  transition: border-color 0.12s, box-shadow 0.12s, transform 0.06s;\n}\n.tile:hover { border-color: var(--accent); box-shadow: var(--shadow); }\n.tile:active { transform: translateY(1px); }\n.tile.is-active { border-color: var(--accent); background: var(--accent-soft); box-shadow: var(--shadow); }\n.tile.is-terminal { opacity: 0.92; }\n.tile .tile-count { font-size: 28px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }\n.tile .tile-label { font-size: 13px; color: var(--ink-soft); }\n.tile .tile-tag { font-size: 11px; font-weight: 600; color: var(--ink-soft); text-transform: uppercase; letter-spacing: 0.05em; }\n\n/* Stat rows */\n.stat-row { display: flex; flex-wrap: wrap; gap: 28px; }\n.stat { display: flex; flex-direction: column; gap: 2px; }\n.stat .stat-value { font-size: 24px; font-weight: 700; font-variant-numeric: tabular-nums; }\n.stat .stat-label { font-size: 12px; color: var(--ink-soft); }\n.stat .stat-value.danger { color: var(--danger); }\n.stat .stat-value.ok { color: var(--ok); }\n\n/* Table */\n.table { width: 100%; border-collapse: collapse; font-size: 14px; }\n.table th {\n  text-align: left;\n  font-size: 12px;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: var(--ink-soft);\n  font-weight: 600;\n  padding: 8px 12px;\n  border-bottom: 1px solid var(--border);\n}\n.table td { padding: 10px 12px; border-bottom: 1px solid var(--border); }\n.table tr:last-child td { border-bottom: none; }\n.table tr:hover td { background: #fafbfc; }\n.table td.num { text-align: right; font-variant-numeric: tabular-nums; }\n\n.badge {\n  display: inline-block;\n  font-size: 11px;\n  font-weight: 600;\n  padding: 2px 8px;\n  border-radius: 999px;\n  background: var(--accent-soft);\n  color: var(--accent);\n}\n.badge.danger { background: var(--danger-soft); color: var(--danger); }\n\n.btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  text-decoration: none;\n  font-size: 14px;\n  font-weight: 600;\n  color: #fff;\n  background: var(--accent);\n  border: none;\n  border-radius: 8px;\n  padding: 9px 16px;\n  cursor: pointer;\n}\n.btn:hover { background: #2860d6; }\n\n.muted { color: var(--ink-soft); font-size: 14px; }\n.error { color: var(--danger); }\n"}}
